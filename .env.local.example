# Copy this file to .env.local and fill in real values.
# .env.local is gitignored by default.

# Required — your Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-...

# Amazon Associates tracking tag (e.g. "yourtag-20").
# Sign up at https://affiliate-program.amazon.com — you can use a temporary
# tag for v1 development even before approval is finalized.
AMAZON_AFFILIATE_TAG=REPLACE-WITH-YOUR-TAG-20
